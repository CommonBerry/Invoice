{
  "name": "@henriquehnnm/invoice",
  "description": "Manage your freelance projects elegantly",
  "author": "Henrique Sardinha",
  "main": "src/index.ts",
  "module": "index.ts",
  "version": "1.0.4",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "mkdir -p dist && bun build src/index.ts --compile --minify --outfile ./dist/invoice",
    "install": "bun run build && mkdir -p ~/.local/bin && cp ./dist/invoice ~/.local/bin/invoice"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.10",
    "@types/bun": "latest",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@clack/prompts": "^1.0.1",
    "@inkjs/ui": "^2.0.0",
    "cli-table3": "^0.6.5",
    "commander": "^14.0.3",
    "papaparse": "^5.5.3",
    "pdfkit": "^0.18.0",
    "picocolors": "^1.1.1",
    "zod": "^4.3.6"
  },
  "bin": {
    "invoice": "./src/index.ts"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "src",
    "README.md"
  ],
  "keywords": [
    "cli",
    "invoice",
    "bun"
  ],
  "license": "GPL-3.0"
}
